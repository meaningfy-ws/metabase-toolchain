# =============================================================================
# metabase-toolchain local development environment
# =============================================================================
# Copy to ./.env at the repo root:
#     cp .env.example .env
#
# Consumed by both:
#   - Python CLIs (import_metabase, export_metabase, manage_snapshot_db)
#     loaded via dotenv at import time.
#   - docker-compose (`make up`) via --env-file .env, for ${VAR:-default}
#     substitution in infra/docker-compose.yml.
#
# Values here are local-dev defaults only — no secrets. Safe to commit as-is.
# Any real deployment MUST override every value.
# =============================================================================

# --- Python CLI (application) -------------------------------------------------
METABASE_HOST=http://localhost:3001
METABASE_USER=a@a.com
METABASE_PASSWORD=okokok123
METABASE_DB_NAME=TEDSWS MongoDB
DB_AUTH_URL=mongodb://localhost:27018
DB_NAME=aggregates_db

# --- Metabase container (infra) -----------------------------------------------
METABASE_VERSION=v0.44.6
METABASE_HOST_PORT=3001
MB_SITE_URL=http://localhost:3001
JAVA_TIMEZONE=UTC

# --- Metabase app database / Postgres container (infra) -----------------------
MB_DB_DBNAME=metabaseappdb
MB_DB_USER=metabase
MB_DB_PASSWORD=metabase
MB_DB_HOST_PORT=5432

# --- MongoDB container (infra) ------------------------------------------------
MONGO_VERSION=6
MONGO_HOST_PORT=27018
